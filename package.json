{
  "name": "greenplus",
  "private": true,
  "packageManager": "npm@10.5.0",
  "workspaces": [
    "web-admin",
    "web-client",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --ui=tui",
    "dev:admin": "turbo dev --filter=web-admin",
    "dev:client": "turbo dev --filter=web-client",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "dotenv": "^16.6.1",
    "turbo": "^2.8.19"
  },
  "dependencies": {
    "@logtail/next": "^0.3.1",
    "@logtail/node": "^0.5.8",
    "@supabase/supabase-js": "^2.102.1"
  }
}
