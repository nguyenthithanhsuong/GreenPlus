{
  "name": "greenplus",
  "private": true,
  "packageManager": "npm@10.5.0",
  "workspaces": [
    "web-admin",
    "web-client",
    "supabase-playground",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo build && turbo dev --ui=tui",
    "dev:admin": "turbo build --filter=web-admin && turbo dev --filter=web-admin",
    "dev:client": "turbo build --filter=web-client && turbo dev --filter=web-client",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "turbo": "^2.8.19"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2"
  }
}
