{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_DSN",
    "NEXT_PUBLIC_SENTRY_DSN"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "outputs": ["dist/**", ".next/**"]
    },
    "lint": {},
    "typecheck": {
      "outputs": [],
      "cache": true
    }
  }
}